# DeFi MCP Server — Environment Variables

# CoinGecko API (optional — free tier works without key, Pro key increases rate limits)
COINGECKO_API_KEY=

# Etherscan API (optional — for token holdings lookup)
ETHERSCAN_API_KEY=

# 1inch API key (optional — for DEX quotes, free at portal.1inch.dev)
ONEINCH_API_KEY=

# Public RPC endpoints (defaults provided, override for reliability)
ETH_RPC_URL=https://ethereum.publicnode.com
BSC_RPC_URL=https://bsc.publicnode.com

# Server transport (stdio for Claude Desktop, http for remote agents)
MCP_TRANSPORT=stdio
MCP_PORT=3000
